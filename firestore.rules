rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserBengkelId() {
      return request.auth.token.bengkelId;
    }

    function isOwner() {
      return request.auth.token.role == 'owner';
    }

    function isStaff() {
      return request.auth.token.role == 'staff';
    }

    function isMember(bengkelId) {
      return isSignedIn() && getUserBengkelId() == bengkelId;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BENGKEL ROOT COLLECTION
    // ─────────────────────────────────────────────────────────────────────────

    match /bengkel/{bengkelId} {

      // Siapa saja yang sudah login bisa cek ketersediaan bengkelId
      allow get: if isSignedIn();
      // Hanya member bengkel ini yang bisa list/query
      allow list: if isMember(bengkelId);
      // Siapa saja yang sudah login bisa buat bengkel baru
      allow create: if isSignedIn();
      // Hanya owner yang bisa update/delete data bengkel
      allow update, delete: if isMember(bengkelId) && isOwner();

      // ── Permission helper (membaca customPermissions dari dokumen staff) ──
      function hasStaffPermission(permission) {
        let staffDoc = get(/databases/$(database)/documents/bengkel/$(bengkelId)/staff/$(request.auth.uid));
        return staffDoc.data.customPermissions != null
          && staffDoc.data.customPermissions[permission] == true;
      }

      // ── TRANSACTIONS ──────────────────────────────────────────────────────
      match /transactions/{documentId} {
        allow read: if isMember(bengkelId);
        allow create: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('transaksi_create'));
        allow update: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('transaksi_update'));
        allow delete: if isMember(bengkelId) && isOwner();

        // Items sub-subcollection (mirroring parent transaction permissions)
        match /items/{itemId} {
          allow read: if isMember(bengkelId);
          allow create: if isMember(bengkelId)
            && (isOwner() || hasStaffPermission('transaksi_create'));
          allow update: if isMember(bengkelId)
            && (isOwner() || hasStaffPermission('transaksi_update'));
          allow delete: if isMember(bengkelId) && isOwner();
        }
      }

      // ── STOK (ObjectBox sync — legacy collection name) ────────────────────
      match /stok/{documentId} {
        allow read: if isMember(bengkelId);
        allow create: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('stok_create'));
        allow update: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('stok_update_jumlah'));
        allow delete: if isMember(bengkelId) && isOwner();
      }

      // ── INVENTORY (Firestore sync collection name) ────────────────────────
      match /inventory/{documentId} {
        allow read: if isMember(bengkelId);
        allow create: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('stok_create'));
        allow update: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('stok_update_jumlah'));
        allow delete: if isMember(bengkelId) && isOwner();
      }

      // ── CUSTOMERS ─────────────────────────────────────────────────────────
      match /customers/{documentId} {
        allow read: if isMember(bengkelId);
        allow create: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('pelanggan_create'));
        allow update: if isMember(bengkelId)
          && (isOwner() || hasStaffPermission('pelanggan_update'));
        allow delete: if isMember(bengkelId) && isOwner();
      }

      // ── VEHICLES ──────────────────────────────────────────────────────────
      // Staff perlu bisa tambah/edit kendaraan saat membuat transaksi
      match /vehicles/{documentId} {
        allow read: if isMember(bengkelId);
        allow create, update: if isMember(bengkelId)
          && (isOwner() || isStaff());
        allow delete: if isMember(bengkelId) && isOwner();
      }

      // ── STAFF (sync data, bukan permission management) ────────────────────
      // Hanya owner yang bisa kelola data staff
      match /staff/{documentId} {
        allow read: if isMember(bengkelId);
        allow create, update: if isMember(bengkelId) && isOwner();
        allow delete: if isMember(bengkelId) && isOwner();
      }

      // ── INVENTORY HISTORY ─────────────────────────────────────────────────
      // Staff bisa create (otomatis saat transaksi), tapi tidak bisa edit/hapus
      match /inventory_history/{documentId} {
        allow read: if isMember(bengkelId);
        allow create: if isMember(bengkelId)
          && (isOwner() || isStaff());
        allow update, delete: if isMember(bengkelId) && isOwner();
      }

      // ── SECRETS (master key storage) ──────────────────────────────────────
      match /secrets/{documentId} {
        allow read: if isMember(bengkelId) && isOwner();
        allow create: if isSignedIn() && (
          (isMember(bengkelId) && isOwner()) ||
          (getAfter(/databases/$(database)/documents/bengkel/$(bengkelId)).data.ownerUid == request.auth.uid)
        );
        allow update: if isMember(bengkelId) && isOwner();
        allow delete: if false;
      }

      // ── SECURITY AUDIT LOGS ───────────────────────────────────────────────
      // Hanya owner yang bisa baca. Tidak ada yang bisa tulis dari client —
      // hanya Cloud Functions yang boleh menulis ke sini.
      match /security_audit_logs/{documentId} {
        allow read: if isMember(bengkelId) && isOwner();
        allow write: if false;
      }

      // ── OPERATIONS (idempotency keys) ─────────────────────────────────────
      // Semua member perlu bisa baca & tulis untuk idempotency check saat sync
      match /_operations/{documentId} {
        allow read, write: if isMember(bengkelId);
      }

      // ── INTERNAL (migration status, config) ───────────────────────────────
      match /_internal/{documentId} {
        allow read: if isMember(bengkelId);
        allow write: if isMember(bengkelId) && isOwner();
      }

      // ── FALLBACK: deny semua subcollection yang tidak terdaftar ──────────
      // Subcollection baru tidak otomatis dapat akses — harus didaftarkan eksplisit
      match /{unknownSubcollection}/{documentId} {
        allow read, write: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOP-LEVEL COLLECTIONS (partitioned by bengkelId field)
    // ─────────────────────────────────────────────────────────────────────────

    function getIncomingBengkelId() {
      return request.resource != null && request.resource.data != null
        ? request.resource.data.bengkelId
        : null;
    }

    function resourceMatchesBengkel(bengkelId) {
      let incomingId = getIncomingBengkelId();
      return (request.method == 'create' && incomingId == bengkelId)
          || (resource != null && resource.data != null && resource.data.bengkelId == bengkelId);
    }

    match /transactions/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    match /stok/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    match /pelanggans/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && (isOwner() || isStaff())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && (isOwner() || isStaff())
                    && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    match /staff/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && isOwner() && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && isOwner()
                    && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BENGKELS COLLECTION (permission management — collection terpisah)
    // Dipakai oleh permission_service.dart untuk staff permissions & role templates
    // ─────────────────────────────────────────────────────────────────────────

    match /bengkels/{bengkelId} {
      allow read, write: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();

      match /staff/{staffId} {
        // Owner bisa kelola semua staff
        allow read, write: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
        // Staff hanya bisa baca dokumen dirinya sendiri (untuk cek permission sendiri)
        allow read: if isSignedIn() && getUserBengkelId() == bengkelId
          && request.auth.uid == staffId;
      }

      match /role_templates/{templateId} {
        // Hanya owner yang bisa kelola role templates
        allow read, write: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // USERS / PROFILES
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // INTERNAL CONFIGURATION (top-level, read-only untuk authenticated users)
    // ─────────────────────────────────────────────────────────────────────────

    match /_internal/{configId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
