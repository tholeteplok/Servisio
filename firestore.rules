rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Pendekatan Hybrid: Cek owner langsung, cek staff via members subcollection
    // Ini lebih efisien dan fleksibel untuk Firebase Rules dibanding list hasAny.
    function canAccessWorkshop(ownerId, workshopId) {
      return isSignedIn() && (
        request.auth.uid == ownerId || 
        exists(/databases/$(database)/documents/users/$(ownerId)/workshops/$(workshopId)/members/$(request.auth.uid))
      );
    }

    function isWorkshopOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function getMemberData(ownerId, workshopId) {
      return get(/databases/$(database)/documents/users/$(ownerId)/workshops/$(workshopId)/members/$(request.auth.uid)).data;
    }

    function hasPermission(ownerId, workshopId, perm) {
      let data = getMemberData(ownerId, workshopId);
      return data.permissions != null && data.permissions[perm] == true;
    }

    // ── WORKSHOP NESTED STRUCTURE ────────────────────────────────────────────

    match /users/{ownerId}/workshops/{workshopId} {
      
      // Workshop doc itself
      allow get: if canAccessWorkshop(ownerId, workshopId);
      allow create, update, delete: if isWorkshopOwner(ownerId);

      // Standard Collections (Transactions, Stok, Customers, etc)
      match /{collectionName}/{docId} {
        allow read: if canAccessWorkshop(ownerId, workshopId);
        
        allow create, update: if canAccessWorkshop(ownerId, workshopId) && (
          isWorkshopOwner(ownerId) || 
          // Cek permission spesifik jika teknisi/admin
          (collectionName == 'transactions' && hasPermission(ownerId, workshopId, 'transaksi_write')) ||
          (collectionName == 'stok' && hasPermission(ownerId, workshopId, 'stok_write')) ||
          (collectionName == 'customers' && hasPermission(ownerId, workshopId, 'pelanggan_write')) ||
          // Default untuk collection lain jika member
          true 
        );

        allow delete: if isWorkshopOwner(ownerId);

        // Sub-sub collections (items, history, dll)
        match /{subCollection}/{subId} {
           allow read: if canAccessWorkshop(ownerId, workshopId);
           allow write: if canAccessWorkshop(ownerId, workshopId) && (
             isWorkshopOwner(ownerId) || true
           );
        }
      }

      // Members management
      match /members/{memberId} {
        allow read: if canAccessWorkshop(ownerId, workshopId);
        allow write: if isWorkshopOwner(ownerId);
      }

      // Settings & Internal
      match /settings/{docId} {
        allow read: if canAccessWorkshop(ownerId, workshopId);
        allow write: if isWorkshopOwner(ownerId);
      }
      
      match /_operations/{docId} {
        allow read, write: if canAccessWorkshop(ownerId, workshopId);
      }
    }

    // ── USER PROFILES ────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId);
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── LEGACY & TOP-LEVEL FALLBACK ─────────────────────────────────────────
    // Path lama untuk kompatibilitas dengan data yang belum migrasi
    // FIX: Tambahkan akses ke sub-koleksi untuk sinkronisasi
    
    match /bengkel/{bengkelId} {
       // Get diizinkan agar fitur "Cek Ketersediaan" dan "Join" bisa mencari owner.
       allow get: if isSignedIn();
       
       // Create diizinkan saat pendaftaran awal bengkel baru.
       allow create: if isSignedIn();
       
       // Update hanya bisa dilakukan oleh owner bengkel tersebut.
       allow update: if isSignedIn() && (
         resource.data.ownerUid == request.auth.uid ||
         request.auth.uid == request.resource.data.ownerUid
       );
       
       // List dan Delete dilarang untuk keamanan registry.
       allow list, delete: if false;

       // ✅ FIX: Izinkan akses ke sub-koleksi untuk sinkronisasi legacy path
       // Ini penting untuk data yang belum migrasi ke nested path
       match /{collectionName}/{docId} {
         allow read: if isSignedIn() && (
           resource.data.bengkelId == bengkelId ||
           request.resource.data.bengkelId == bengkelId
         );
         allow create, update: if isSignedIn() && (
           request.resource.data.bengkelId == bengkelId
         );
         allow delete: if false; // Soft delete preferred
       }

       // ✅ FIX: Izinkan member baca secrets subcollection untuk key recovery
       // saat install ulang / join device baru.
       match /secrets/{docId} {
         allow get: if isSignedIn();
         allow write: if false; // Key rotation hanya via Cloud Function atau owner
       }
    }

    match /_internal/{configId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
